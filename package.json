{
  "name": "@uxmaltech/collab-cli",
  "version": "0.1.10",
  "description": "CLI for collaborative architecture and delivery workflows.",
  "private": false,
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "collab": "bin/collab"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin",
    "dist",
    "queries",
    "README.md",
    "LICENSE",
    "install.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "pack:dry-run": "npm pack --dry-run",
    "start": "node dist/index.js",
    "test": "npm run build && node scripts/run-tests.mjs",
    "test:e2e": "npm run build && COLLAB_RUN_E2E=1 node --test tests/e2e/full-flow.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.2",
    "semver": "^7.7.3",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
